<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2AFFEB3B"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Quên Mật Khẩu"
        android:textColor="#82B1FF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#990D0D"
        android:hint="Nhập email đã đăng ký"
        android:inputType="textEmailAddress" />

    <Button
        android:id="@+id/btnSendCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#47ED0B0B"
        android:text="Gửi mã xác nhận"
        android:textColor="#FFE57F" />

    <!-- Layout xác nhận mã -->
    <LinearLayout
        android:id="@+id/layoutVerifyCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/etVerificationCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#990D0D"
            android:hint="Nhập mã xác nhận (6 số)"
            android:inputType="number"
            android:maxLength="6" />

        <Button
            android:id="@+id/btnVerifyCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#47ED0B0B"
            android:text="Xác nhận mã"
            android:textColor="#FFE57F" />
    </LinearLayout>

    <!-- Layout đặt lại mật khẩu -->
    <LinearLayout
        android:id="@+id/layoutResetPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#990D0D"
            android:hint="Mật khẩu mới"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/etConfirmNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#990D0D"
            android:hint="Xác nhận mật khẩu mới"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnResetPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#47ED0B0B"
            android:text="Đặt lại mật khẩu"
            android:textColor="#FFE57F" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        android:text="Quay lại đăng nhập"
        android:textColor="#82B1FF" />

</LinearLayout>